# Stage0 API Configuration
# Get your API key from https://signalpulse.org

# Your Stage0 API key (required for production)
STAGE0_API_KEY=your_api_key_here

# Stage0 API base URL (default: https://api.signalpulse.org)
STAGE0_BASE_URL=https://api.signalpulse.org

# Optional: Enable debug logging
# STAGE0_DEBUG=true